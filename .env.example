# Telegram bot
TELEGRAM_BOT_TOKEN=
# Username of the bot (without @). Used to generate t.me/<username>?start=... deep links
# so users can link their Telegram chat to their web account from /wallet.
TELEGRAM_BOT_USERNAME=

# Public URL of the web app — embedded in Telegram completion notifications.
WEB_PUBLIC_URL=https://cheat.rivanair.in

# Comma-separated list of group chat IDs that can use this bot.
# Get a chat ID by adding the bot to the group, sending /test, then calling
#   curl https://api.telegram.org/bot<TOKEN>/getUpdates
WHITELISTED_GROUP_IDS=

# Per-user daily caps. 0 = unlimited.
DAILY_CAP_CHEATSHEETS=0
DAILY_CAP_BOOKS=0

# Whisper transcription backend.
#   groq   - Groq Whisper API. Free, ~28k audio-seconds/hour rate limit.
#   local  - Self-hosted faster-whisper. No rate limit, ~3-5 min for 30 min audio
#            on CPU. Loads ~1.2 GB into RAM (small model).
#   openai - OpenAI Whisper API ($0.006/audio-min). Set OPENAI_API_KEY.
WHISPER_BACKEND=local
WHISPER_MODEL=small      # tiny | base | small | medium | large-v3
GROQ_API_KEY=

# YouTube download egress. Datacenter VPS IPs are frequently challenged or
# rate-limited by YouTube. Set an authenticated, reputable residential proxy
# in production so yt-dlp can fail over when direct access is blocked.
#
# URL-encode reserved characters in the username/password. Keep these values
# only in .env (never commit them). Example shape:
#   http://username:password@proxy.example.com:8000
YTDLP_PROXY_URL=
# Optional comma-separated failover pool. When set, it takes precedence over
# YTDLP_PROXY_URL. Do not put commas inside encoded credentials.
YTDLP_PROXY_POOL=
# Fallback single-proxy secret managed from Admin -> yt-dlp cookies & storage.
# YTDLP_PROXY_POOL and YTDLP_PROXY_URL always take precedence. The admin API
# writes this file atomically with mode 0600 and never returns its contents.
YTDLP_PROXY_FILE=/home/botuser/.config/cheetsheet/ytdlp_proxy_url
# Optional Netscape cookies file. Cookies are used only when YouTube actually
# requires sign-in; they do not repair an IP-level HTTP 429 block.
YT_COOKIES_PATH=/home/botuser/cookies.txt

# Authoring (markdown writer). Options:
#   claude_code  - Uses Claude Code CLI on the host. Bills against Max sub. Best quality.
#   groq         - Uses Groq Llama. Free but uses map-reduce (lossy). Faster set up.
#   openai       - Uses GPT-4o-mini. ~$0.005/cheatsheet. Needs OPENAI_API_KEY.
#   anthropic    - Uses Sonnet. ~$0.06/cheatsheet. Needs ANTHROPIC_API_KEY.
AUTHORING_PROVIDER=claude_code
AUTHORING_MODEL=llama-3.1-8b-instant   # only used when provider != claude_code

# Path to the claude binary. Empty = "claude" on PATH (Linux/VPS default).
CLAUDE_CODE_BIN=

# Optional paid keys (leave blank if not using):
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Web app (Phase 1: Auth + DB) -------------------------------------------

# DB connection. Local dev: SQLite via aiosqlite. Prod: postgresql+asyncpg://...
DATABASE_URL=sqlite+aiosqlite:///./web_work/app.db

# NextAuth.js / Auth.js v5
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth client (from console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Shared secret between Next.js middleware and FastAPI for X-User-ID injection.
# FastAPI only trusts the X-User-ID header when X-Internal-Token matches.
INTERNAL_API_TOKEN=

# --- Admin portal ----------------------------------------------------------
# Comma-separated list of emails granted access to /admin and /api/admin/*.
# Both the Next.js middleware and FastAPI check this list — must be set in
# both .env files so the web app and API agree.
ADMIN_EMAILS=

# --- Razorpay (wallet top-ups) ---------------------------------------------
# Get test keys from: Razorpay Dashboard → Account & Settings → API Keys.
# Leave blank to disable wallet payments (admin credit + promo redemption
# still work; /api/wallet/order returns 503 until these are set).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
